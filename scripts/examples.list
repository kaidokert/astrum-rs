    irq_ring_overflow_test
    irq_repend_stress_test
    irq_disable_test
    systick_preempt_test
    uart_irq_demo
)

# Dynamic-MPU examples exercise MPU region configuration with
# unprivileged partition execution (CONTROL.nPRIV=1).
DYNAMIC_MPU_EXAMPLES=(
    # Disabled pending boot sentinel-MPU fix (precompute_mpu_cache rejects size=0):
    # buf_lend_rw_test buf_lend_ro_test buf_transfer_test buf_deadline_test peripheral_buf_lend_test
    buf_lend_addr_test buf_error_test buf_align_boot_test
    pendsv_primask_dynamic_test
    plib_dev_read_timed_test
    single_periph_boot_test
    asymmetric_periph_test
    # Disabled pending MPU config fixes:
    # mpu_dynamic_test buffer_pool_test virtual_uart_demo
    uart1_loopback
)

# QEMU peripheral examples require the tudelft-lm3s6965-pac PAC crate
# for typed MMIO register access to LM3S6965 peripherals.
QEMU_PERIPHERAL_EXAMPLES=(
    qemu_pac_uart0
    qemu_pac_i2c0
    qemu_pac_adc0
    qemu_pac_ssi0
    qemu_pac_timer0_periodic
    qemu_pac_timer0_pwm
    qemu_pac_pwm0
    qemu_pac_pwm0_deadband
    qemu_pac_pwm0_multichannel
    qemu_pac_timer0_capture
    qemu_pac_timer_chain
)

# Health partition examples exercise the health monitoring subsystem
# which tracks partition liveness and schedule integrity.
HEALTH_PARTITION_EXAMPLES=(
    health_partition_test
    health_stall_detect_test
)

# Porting guide examples (00-09) demonstrate progressive board bring-up
# steps from bare-metal context switching through full kernel IPC.
PORTING_GUIDE_EXAMPLES=(
    00_context_switch
    01_mpu_static
    02_mpu_dynamic
    03_svc_handler
    04_schedule_table
    05_sampling_port
    06_kernel_minimal
    07_queuing_ports
    08_semaphores
    09_full_demo
)
