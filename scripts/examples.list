# Canonical QEMU example lists — sourced by ci.sh and run-qemu-examples.sh.
# shellcheck shell=bash

EXAMPLES=(
    qemu_smoke
    qemu_smoke_4k
    smoke_test
    mpu_region systick mpu_wx mpu_fault
    partition_switch context_switch mpu_partition
    svc_yield integration
    sampling_demo blackboard_demo
    # Disabled: queuing_demo is intermittent (response mismatch race ~1/3 runs):
    # queuing_demo
    priv_fault_test get_time_test blocking_deschedule
    # Adversarial tests
    read_kernel_mem read_other_stack write_other_stack stack_guard
    write_mpu_regs disable_interrupts write_kernel_mem write_control
    syscall_kernel_ptr syscall_other_ptr syscall_bad_ids syscall_bad_ptrs
    # Privilege / security tests
    priv_drop_test
    # MPU enforcement test
    mpu_enforce_test
    mpu_cached_test
    callee_save_check
    pendsv_primask_test
    pendsv_primask_leak_test
    svcall_primask_clear_test
    svcall_basepri_clear_test
    tick_fairness_test
    all_syscalls_smoke_test
    dropped_tick_test
    pendstclr_systick_test
    # Disabled pending kernel starvation-detection fix (count stays 0):
    # starvation_detect_test
    starvation_counter_test
    pendsv_stack_overflow_test
    boot_banner_test
    # Fault-recovery / survival tests
    adversarial_survive
    # Disabled pending kernel warm-restart invariant fix ("active 0 is Ready"):
    # fault_restart_exhaust_test
    error_handler_test
    run_count_test
    builder_periph_test
    all_faulted_idle_test
    last_partition_faults_test
    restart_hook_test
    # Disabled pending kernel cold-restart data-zeroing fix (zeroed=false):
    # restart_hook_cold_test
)

# Release-only examples require --release because mpu_enforce = true
# causes alignment issues in debug builds.
RELEASE_EXAMPLES=(
    # Disabled pending boot_preconfigured MPU-enforce hang (prints "start" then spins):
    # mpu_precompute_test
    # mpu_periph_precompute_test
)

# Intra-thread examples require the intra-threads feature for
# multi-threaded partition support.
INTRA_THREAD_EXAMPLES=(
    qemu_thread_rr
)

CUSTOM_IVT_EXAMPLES=(
    qemu_custom_ivt
    irq_dispatch_test
    irq_multi_test
    irq_ack_test
