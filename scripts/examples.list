# Canonical QEMU example lists — sourced by ci.sh and run-qemu-examples.sh.
# shellcheck shell=bash

EXAMPLES=(
    qemu_smoke
    qemu_smoke_4k
    smoke_test
    mpu_region systick mpu_wx mpu_fault
    partition_switch context_switch mpu_partition
    svc_yield integration
    sampling_demo queuing_demo blackboard_demo
    priv_fault_test get_time_test blocking_deschedule
    # Adversarial tests
    read_kernel_mem read_other_stack write_other_stack stack_guard
    write_mpu_regs disable_interrupts write_kernel_mem write_control
    syscall_kernel_ptr syscall_other_ptr syscall_bad_ids syscall_bad_ptrs
    # Privilege / security tests
    priv_drop_test
    # MPU enforcement test
    mpu_enforce_test
    mpu_cached_test
    callee_save_check
    pendsv_primask_test
    pendsv_primask_leak_test
    svcall_primask_clear_test
    svcall_basepri_clear_test
    tick_fairness_test
    mpu_precompute_test
    mpu_periph_precompute_test
    all_syscalls_smoke_test
    dropped_tick_test
    pendstclr_systick_test
    starvation_detect_test
    starvation_counter_test
    pendsv_stack_overflow_test
    boot_banner_test
    # Fault-recovery / survival tests
    adversarial_survive
    fault_restart_exhaust_test
    error_handler_test
)

CUSTOM_IVT_EXAMPLES=(
    qemu_custom_ivt
    irq_dispatch_test
    irq_multi_test
    irq_ack_test
    irq_kernel_clears_test
    irq_simultaneous_test
    irq_ack_multi_test
    irq_ack_error_test
    irq_clearbit_test
    irq_mixed_model_test
    irq_unbound_test
    irq_custom_handler_test
    irq_ring_buffer_test
    irq_ring_overflow_test
    irq_repend_stress_test
    irq_disable_test
    systick_preempt_test
    uart_irq_demo
)

# Dynamic-MPU examples exercise MPU region configuration with
# unprivileged partition execution (CONTROL.nPRIV=1).
DYNAMIC_MPU_EXAMPLES=(
    buf_lend_rw_test buf_lend_ro_test buf_transfer_test buf_lend_addr_test buf_deadline_test buf_error_test buf_align_boot_test
    pendsv_primask_dynamic_test
    plib_dev_read_timed_test
    peripheral_buf_lend_test
    single_periph_boot_test
    # Disabled pending MPU config fixes:
    # mpu_dynamic_test buffer_pool_test virtual_uart_demo uart1_loopback
)

# QEMU peripheral examples require the tudelft-lm3s6965-pac PAC crate
# for typed MMIO register access to LM3S6965 peripherals.
QEMU_PERIPHERAL_EXAMPLES=(
    qemu_pac_uart0
    qemu_pac_i2c0
    qemu_pac_adc0
    qemu_pac_ssi0
    qemu_pac_timer0_periodic
    qemu_pac_timer0_pwm
    qemu_pac_pwm0
    qemu_pac_pwm0_deadband
    qemu_pac_pwm0_multichannel
    qemu_pac_timer0_capture
    qemu_pac_timer_chain
)
